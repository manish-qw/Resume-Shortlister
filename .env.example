# Scoring Weights (must sum to 1.0)
WEIGHT_EXACT_MATCH=0.30
WEIGHT_SIMILARITY=0.25
WEIGHT_ACHIEVEMENT=0.25
WEIGHT_OWNERSHIP=0.20

# Tier Thresholds
TIER_A_THRESHOLD=75
TIER_B_THRESHOLD=50

# Semantic Similarity
SIMILARITY_THRESHOLD=0.72
EMBEDDING_MODEL=all-MiniLM-L6-v2

# API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Early Exit: skip expensive LLM scorers if exact match below this
EXACT_MATCH_FLOOR=20

# Server
HOST=0.0.0.0
PORT=8000
